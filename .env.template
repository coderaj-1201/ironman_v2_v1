# ── RAG Enterprise .env template ─────────────────────────────────────────────
# Copy to .env and fill in values. Never commit .env.
# In ACA these are set as environment variables by the Bicep deployment.

# ── Azure AI Foundry ──────────────────────────────────────────────────────────
# Portal: AI Foundry → your project → Overview → "Project endpoint"
AZURE_FOUNDRY_PROJECT_ENDPOINT=https://<hub>.services.ai.azure.com/api/projects/<project>
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ── Azure AI Search ───────────────────────────────────────────────────────────
# Portal: AI Search resource → Overview → Url
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
# Portal: AI Search → Settings → Keys → Primary admin key (LOCAL DEV only)
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX=idx-rag
AZURE_SEARCH_SEMANTIC_CONFIG=rag-semantic-config

# ── Azure Cosmos DB ───────────────────────────────────────────────────────────
# Portal: Cosmos DB account → Overview → URI
# Or run: python scripts/provision_cosmos.py  (prints these values at the end)
AZURE_COSMOS_ENDPOINT=https://<account>.documents.azure.com:443/
# Portal: Cosmos DB → Keys → Primary Key  (LOCAL DEV only; prod uses Managed Identity)
AZURE_COSMOS_KEY=
AZURE_COSMOS_DATABASE=rag-enterprise
AZURE_COSMOS_CONTAINER_CONVERSATIONS=conversations
AZURE_COSMOS_CONTAINER_FEEDBACK=feedback
AZURE_COSMOS_CONTAINER_MEMORY=memory

# ── Azure Provisioning (provision_cosmos.py only) ─────────────────────────────
AZURE_SUBSCRIPTION_ID=<subscription-id>
AZURE_RESOURCE_GROUP=<resource-group>
AZURE_LOCATION=eastus
COSMOS_ACCOUNT_NAME=rag-enterprise-cosmos

# ── Azure Service Bus ─────────────────────────────────────────────────────────
# Portal: Service Bus namespace → Overview → Host name
AZURE_SERVICE_BUS_NAMESPACE=<namespace>.servicebus.windows.net

# ── Azure Entra ID (JWT token validation) ────────────────────────────────────
AZURE_TENANT_ID=<tenant-id>
AZURE_CLIENT_ID=<app-client-id>

# ── RAG tuning ────────────────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.75
MAX_RETRIEVAL_ATTEMPTS=3
RETRIEVAL_TOP_K=5
SYNTHESIS_TEMPERATURE=0.0
SHORT_TERM_MEMORY_TURNS=5

# ── Observability ─────────────────────────────────────────────────────────────
# Portal: App Insights → Overview → Connection String
APPLICATIONINSIGHTS_CONNECTION_STRING=
LOG_LEVEL=INFO
